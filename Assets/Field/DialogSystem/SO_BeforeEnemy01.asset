  m_Name: SO_BeforeEnemy01
  m_EditorClassIdentifier: 
  dialogueLines:
  - speakerName: TENET
    text: 'Master, wait! '
  - speakerName: TENET
    text: "Doesn\u2019t that wolf seem odd to you?\r\n"
  - speakerName: HUGO
    text: "No? Let\u2019s leave it be. We can hunt for food later."
  - speakerName: TENET
    text: "But Master, it looks to be in pain! We can\u2019t just leave it!\r"
  - speakerName: HUGO
    text: "\u2026 "
  - speakerName: HUGO
    text: "Alright. If it pounces, though, I\u2019m giving it sweet release."
  - speakerName: TENET
    text: "Cruel, but reasonable.\r"
