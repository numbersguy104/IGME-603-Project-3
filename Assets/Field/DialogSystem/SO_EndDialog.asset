--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 8ef659fb6f36bdb429daea399a91329e, type: 3}
  m_Name: SO_EndDialog
  m_EditorClassIdentifier: 
  dialogueLines:
  - speakerName: TENET
    text: "Master, you\u2019ve been awfully quiet. What\u2019s on your mind?\r"
  - speakerName: HUGO
    text: "\u2026"
  - speakerName: HUGO
    text: "We\u2019re turning back around.\r\n"
  - speakerName: TENET
    text: "Hmm?! But what about the virus? What about my request?\r"
  - speakerName: HUGO
    text: "It\u2019s not worth it if I become a husk in the process, Tenet! I care
      about living, thank you very much.\r"
  - speakerName: TENET
    text: "Master, why are you so scared of death suddenly?\r"
  - speakerName: HUGO
    text: "I\u2019ve always been! Why is this a question?!"
  - speakerName: TENET
    text: "Is this because your friend died of a disease you couldn\u2019t cure in
      time?\r"
  - speakerName: HUGO
    text: "\u2026Why do you know about that?\r"
  - speakerName: TENET
    text: You forget, Master. I am you, and you are me.
  - speakerName: TENET
    text: "I know how much saving other people's lives matters to you. Please don\u2019t
      let another deadly virus claim more victims.\r\n"
  - speakerName: HUGO
    text: "\u2026 Fine, but don\u2019t bring up my past anymore.\r\n"
  - speakerName: TENET
    text: 'No promises, Master.

'
